# ====================================
# 🔧 CONFIGURACIÓN DE EJEMPLO
# Copia este archivo a .env y rellena con tus valores reales
# ====================================

# Database
DB_PATH=barbershop.db

# Server
PORT=8080

# ====================================
# 📱 WHATSAPP BUSINESS API (Meta)
# Obtén estos valores en: https://developers.facebook.com
# ====================================
WHATSAPP_PHONE_NUMBER_ID=123456789012345
WHATSAPP_ACCESS_TOKEN=EAABcdefghijklmnopqrstuvwxyz1234567890ABCDEFGHIJKLMNOPQRSTUVWXYZ
WHATSAPP_VERIFY_TOKEN=mi_token_secreto_webhook_12345

# ====================================
# 💈 CONFIGURACIÓN DE LA BARBERÍA
# ====================================
BARBERSHOP_NAME=Mi Barbería
BARBERSHOP_OWNER_PHONE=5491234567890

# ====================================
# 🔐 CREDENCIALES DE ADMIN
# Cambiar en producción
# ====================================
ADMIN_USERNAME=admin
ADMIN_PASSWORD=contraseña_segura_123

# ====================================
# 🔑 JWT (Autenticación)
# Usa una clave única y segura en producción
# ====================================
JWT_SECRET=7a3f8c2d1e9b4f6a5c0d7e2f3a4b5c6d7e8f9a0b1c2d3e4f5a6b7c8d9e0f1a2b
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
