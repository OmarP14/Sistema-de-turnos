# Copiar este archivo como .env y completar los valores

# Base de datos
DB_PATH=./barbershop.db

# Servidor
PORT=8080

# CORS — URL del frontend en producción (separar con coma si hay varios)
CORS_ORIGINS=http://localhost:5173

# Admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=elegir_una_contraseña_segura

# JWT — cadena larga y aleatoria, nunca compartir
JWT_SECRET=generar_una_clave_secreta_larga_aqui

# WhatsApp (fallback — se puede configurar desde el panel)
WHATSAPP_VERIFY_TOKEN=barberapp2025
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
BARBERSHOP_NAME=Mi Barbería
BARBERSHOP_OWNER_PHONE=
